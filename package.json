    "@stacks/transactions": "^6.17.0",
    "chokidar-cli": "^3.0.0",
    "dotenv": "^17.4.2",
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "vitest": "^1.3.1",
    "vitest-environment-clarinet": "^2.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
